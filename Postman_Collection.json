								"value": "Bearer {{jwt_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Wireless Mouse\",\n    \"description\": \"Ergonomic mouse\",\n    \"price\": 29.99,\n    \"stock\": 100,\n    \"category\": \"Electronics\",\n    \"imageUrl\": \"http://example.com/mouse.jpg\",\n    \"rating\": 4.5\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/products",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"products"
							]
						}
					}
				},
